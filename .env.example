# Cerebras API key — required for live Gemma 4 analysis. Get one at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Model id served by Cerebras. Gemma 4 31B (multimodal) is the hackathon model.
CEREBRAS_MODEL=gemma-4-31b

# Optional Gemini comparison — used by the Speed tab's Compare button.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Optional: reasoning effort (low | medium | high). Omitted by default — set only if your model supports it.
# CEREBRAS_REASONING_EFFORT=
# GEMINI_REASONING_EFFORT=
